{
  "batch_size": 16,
  "num_epochs": 25,
  "learning_rate": 8e-5,
  "num_classes": 100,
  "data_dir": "./Dataset/data",

  "checkpoint_path": "./Model_Weight/checkpoint.pth",
  "best_model_path": "./Model_Weight/best_model.pth",
  "best_loss_model_path": "./Model_Weight/best_loss_model.pth",

  "resume_training": false,
  "early_stopping_patience": 30,

  "num_subcenters": 3,
  "embed_dim": 256,

  "local1_view_weight": 0.0,
  "proto_diversity_weight": 0.01,

  "local_crop_threshold": 0.45,
  "local_crop_padding_ratio": 0.18,
  "local_min_crop_ratio": 0.3,
  "local_max_crop_ratio": 0.85,
  "local_fallback_crop_ratio": 0.5
}
